// Generate NE and WA sub-populations from out-of-Africa
s1 1e6 early() {
	// NE is N_p2 individuals with 100% out-of-Africa ancestry
	sim.addSubpop("p2", N_p2);
	p2.setMigrationRates(p1, 1.0);
	// WA is N_p3 individuals with 100% out-of-Africa ancestry
	sim.addSubpop("p3", N_p3);
	p3.setMigrationRates(p1, 1.0);
}

// Terminate out-of-Africa population
s2 1e6 late() {
	p2.setMigrationRates(p1, 0.0);
	p3.setMigrationRates(p1, 0.0);
	p1.setSubpopulationSize(0);
}
// Generate CHG and ANA sub-populations from WA
s3 1e6 early() {
	// CHG is N_p4 individuals with 100% WA ancestry
	sim.addSubpop("p4", N_p4);
	p4.setMigrationRates(p3, 1.0);
	// ANA is N_p5 individuals with 100% WA ancestry
	sim.addSubpop("p5", N_p5);
	p5.setMigrationRates(p3, 1.0);
}

// Terminate WA population
s4 1e6 late() {
	p4.setMigrationRates(p3, 0.0);
	p5.setMigrationRates(p3, 0.0);
	p3.setSubpopulationSize(0);
}
// Generate WHG and EHG sub-populations from NE
s5 1e6 early() {
	// WHG is N_p6 individuals with 100% NE ancestry
	sim.addSubpop("p6", N_p6);
	p6.setMigrationRates(p2, 1.0);
	// EHG is N_p7 individuals with 100% NE ancestry
	sim.addSubpop("p7", N_p7);
	p7.setMigrationRates(p2, 1.0);
}

// Terminate NE population
s6 1e6 late() {
	p6.setMigrationRates(p2, 0.0);
	p7.setMigrationRates(p2, 0.0);
	p2.setSubpopulationSize(0);
}
// Generate Neo from WHG and ANA
s7 1e6 early() {
	// Neo is N_p8 individuals with 25% WHG, 75% ANA ancestry
	sim.addSubpop("p8", N_p8);
	p8.setMigrationRates(c(p6, p5), c(0.25, 0.75));
}

// Terminate WHG and ANA
s8 1e6 late() {
	p8.setMigrationRates(c(p6, p5), c(0.0, 0.0));
	p6.setSubpopulationSize(0);
	p5.setSubpopulationSize(0);
}

// Generate Yam from CHG and EHG
s9 1e6 early() {
	// Yam is N_p9 individuals with 50% CHG, 50% EHG ancestry
	sim.addSubpop("p9", N_p9);
	p9.setMigrationRates(c(p4, p7), c(0.5, 0.5));
}

// Terminate WHG and ANA
s10 1e6 late() {
	p9.setMigrationRates(c(p4, p7), c(0.0, 0.0));
	p4.setSubpopulationSize(0);
	p7.setSubpopulationSize(0);
}
// Generate Bronze Age from Neo and Yam
s11 1e6 early() {
	// Bronze Age is N_p10 individuals with 50% Neo, 50% Yam ancestry
	sim.addSubpop("p10", N_p10);
	p10.setMigrationRates(c(p8, p9), c(0.5, 0.5));
}

// Terminate Neo and Yam
s12 1e6 late() {
	p10.setMigrationRates(c(p8, p9), c(0.0, 0.0));
	p8.setSubpopulationSize(0);
	p9.setSubpopulationSize(0);
}

// If running a simulation with de novo positively-selected variation, periodically
// check whether the de novo variant has been expunged from the genome and, if so,
// restart the simulation at the saved tick
s19 1e6 late() {
	mut = sim.mutationsOfType(m4);
	if (size(mut) == 1){
		if (sim.mutationFrequencies(NULL, mut) > MinDAF){
			cat("\n\nPositively-selected mutation introduced with seed " + asString(getSeed()) + " successfully reached allele frequency " + asString(MinDAF) );
			community.deregisterScriptBlock(self);
		}
	}else{
		new_seed=rdunif(1, 0, asInteger(2^62) - 1);
		cat("\nPositively-selected mutation introduced with seed " + asString(getSeed()) + " lost at generation " + asString(community.tick) + "\nRestarting at generation " + asString(ShiftGen) + ", seed " + asString(new_seed)+ "...\n\n");
		// go back to tick ShiftGen
		sim.readFromPopulationFile(StateFilename);
      // start a newly seeded run
      setSeed(new_seed);
		// Read gene annotations
		AdjustedAnnotationMap=readCSV(AdjustedAnnotationMapName, sep=" ");
		// Find indices of nonneutral genomic elements
		NonneutralIndices=which(AdjustedAnnotationMap.getValue("type") != "neutral");
		// Vector of all starting positions for nonneutral genomic elements, 
		// adjusting base pairs to be 0-indexed rather than 1-indexed 
		nonneutral_starts = AdjustedAnnotationMap.getValue("start_bp_1indexed")[NonneutralIndices] - 1;
		// Vector of all ending positions for nonneutral genomic elements, 
		// adjusting base pairs to be 0-indexed rather than 1-indexed 
		nonneutral_ends = AdjustedAnnotationMap.getValue("end_bp_1indexed")[NonneutralIndices] - 1;
		// Get all genomes so you can either check allele frequencies or introduce de novo mutation
		all_genomes = sim.subpopulations.individuals.genomes;
		// Sample a base pair in either a coding or noncoding region
		sampled_index = sample(0:(length(nonneutral_starts)-1), 1);
		sampled_basepair = sample(nonneutral_starts[sampled_index]:nonneutral_ends[sampled_index], 1);
		// Doublecheck the sampled mutation is in a nonneutral region
		original_index=which((AdjustedAnnotationMap.getValue("start_bp_1indexed") - 1) == nonneutral_starts[sampled_index]);
		if(AdjustedAnnotationMap.getValue("type")[original_index] == "neutral"){
			error_message = paste0("\n\nERROR Attempted to introduce a positively-selected mutation to a base pair (", sampled_basepair, ") in a neutral region\n\n");
			stop(message = error_message);
		}
		// Introduce an m4 mutation to the chosen coding or noncoding base pair
		// in a random genome
      target_genome = sample(all_genomes, 1);
      target_genome.addNewDrawnMutation(m4, sampled_basepair);
		// Print the newly-introduced mutation
		cat(paste0("\n\nMutation ", target_genome.mutationsOfType(m4), " introduced to genome ", target_genome, " at base pair ", asString(sampled_basepair), "\n\n"));
	}
}
