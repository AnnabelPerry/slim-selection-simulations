	// Trait-influencing, deleterious mutations (m2 and m3) had selection 
	// coefficients drawn at their inception. If running an Experiment 1 or 3  
	// simulation, use Eyre-Walker Model to translate the pre-assigned 
	// selection coefficient to trait Beta
	tau = 0.5;
	sigma2 = 0.1;
	Ne = 5000;
	s = mut.selectionCoeff;
	mut.setValue("s", s);
	e = rnorm(1, 0.0, sigma2);
	delta = rbinom(1,1,0.5)*2-1;
	beta = delta*abs(4*Ne*s)^tau*(1+e);
	mut.setSelectionCoeff(beta);
	return T;
}
s15 1e6 mutationEffect(m2) {
	// If running an Experiment 3 simulation, m2 and m3 mutations' "selectionCoeff"
	// now contains trait-effect Beta rather than selection coefficient after the 
	// "mutation()" effects. So, you need to manually adjust mutationEffect
	if(E3EC | E3NC){
		h = asInteger(homozygous) * 0.5 + 0.5;
		s = mut.getValue("s");
		effect2 = 1+h*s;
		return effect2;
		// If running an Experiment 1 simulation, there is no variant-level selection. So,
		// mutation effects should be rendered null
	}else if(E1EC | E1NC){
		return 1.0;
	}
}
